#!/usr/bin/env bash
# OpenClaw CLI entry point
# Usage: ./claw "<task>" [--agent <agent_id>] [--session <id>] [--debug]

set -euo pipefail

CLAW_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON="${PYTHON_BIN:-python3}"
ORCHESTRATOR="$CLAW_ROOT/orchestrator/orchestrator.py"

# ── Defaults ─────────────────────────────────────────────────────────────────
TASK=""
AGENT_OVERRIDE=""
SESSION_ID=""
DEBUG=false

# ── Arg parsing ───────────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent)   AGENT_OVERRIDE="$2"; shift 2 ;;
    --session) SESSION_ID="$2";     shift 2 ;;
    --debug)   DEBUG=true;          shift ;;
    --help|-h)
      echo "Usage: claw \"<task>\" [--agent <id>] [--session <id>] [--debug]"
      echo ""
      echo "Agents: orchestrator | research | builder | ops | comms"
      echo ""
      echo "Examples:"
      echo "  ./claw \"research best vector databases for local use\""
      echo "  ./claw \"write a Python script to parse JSON logs\" --agent builder"
      echo "  ./claw \"schedule daily backup of /var/data\" --agent ops"
      echo "  ./claw \"draft a README for this project\" --agent comms"
      exit 0
      ;;
    *)
      TASK="$1"
      shift
      ;;
  esac
done

if [[ -z "$TASK" ]]; then
  echo "[claw] Error: No task provided. Use: ./claw \"<your task>\""
  exit 1
fi

# ── Check dependencies ────────────────────────────────────────────────────────
if ! command -v "$PYTHON" &>/dev/null; then
  echo "[claw] Error: python3 not found. Install Python 3.10+"
  exit 1
fi

if ! command -v opencode &>/dev/null; then
  echo "[claw] Warning: opencode CLI not found. Running in prompt-output mode."
  echo "[claw] Install: npm install -g opencode-ai"
  echo ""
fi

# ── Build env ─────────────────────────────────────────────────────────────────
export CLAW_ROOT
export CLAW_DEBUG="$DEBUG"
[[ -n "$AGENT_OVERRIDE" ]] && export CLAW_AGENT_OVERRIDE="$AGENT_OVERRIDE"
[[ -n "$SESSION_ID" ]]     && export CLAW_SESSION_ID="$SESSION_ID"

# ── Run ───────────────────────────────────────────────────────────────────────
if [[ "$DEBUG" == "true" ]]; then
  echo "[claw] Task:    $TASK"
  echo "[claw] Agent:   ${AGENT_OVERRIDE:-auto-route}"
  echo "[claw] Session: ${SESSION_ID:-auto}"
  echo "[claw] Root:    $CLAW_ROOT"
  echo ""
fi

exec "$PYTHON" "$ORCHESTRATOR" "$TASK"
